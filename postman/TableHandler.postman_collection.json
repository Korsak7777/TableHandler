		{
			"name": "GET /table/{id}",
			"item": [
				{
					"name": "Успешное чтение (по ID из save)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Статус ответа SUCCESS', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('SUCCESS');",
									"});",
									"",
									"pm.test('Ответ содержит все поля TableDto', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.data).to.have.property('id');",
									"    pm.expect(json.data).to.have.property('tableType');",
									"    pm.expect(json.data).to.have.property('tableSource');",
									"    pm.expect(json.data).to.have.property('table');",
									"});",
									"",
									"pm.test('ID совпадает с запрошенным', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.data.id).to.eql(pm.collectionVariables.get('savedTableId'));",
									"});",
									"",
									"pm.test('Таблица содержит данные', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.data.table).to.be.a('string');",
									"    pm.expect(json.data.table.length).to.be.above(0);",
									"    const rows = json.data.table.split('\\n');",
									"    pm.expect(rows.length).to.be.at.least(2);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/table/{{savedTableId}}",
							"host": ["{{baseUrl}}"],
							"path": ["table", "{{savedTableId}}"]
						}
					}
				},
