{
	"info": {
		"name": "TableHandler API",
		"description": "Postman коллекция для тестирования REST API проекта TableHandler.\n\nЭндпоинты:\n- POST /table/save — сохранение таблицы\n- GET /table/{id} — чтение таблицы по ID",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "savedTableId",
			"value": ""
		}
	],
	"item": [
		{
			"name": "POST /table/save",
			"item": [
				{
					"name": "Успешное сохранение",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Статус 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Статус ответа SUCCESS', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('SUCCESS');",
									"});",
									"",
									"pm.test('Ответ содержит ID', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.data).to.have.property('id');",
									"    pm.expect(json.data.id).to.match(",
									"        /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/",
									"    );",
									"    pm.collectionVariables.set('savedTableId', json.data.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/table/save",
							"host": ["{{baseUrl}}"],
							"path": ["table", "save"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"metaData\": {\n    \"type\": \"report\",\n    \"source\": \"api\"\n  },\n  \"table\": \"Col1;Col2;Col3\\nRow1Col1;Row1Col2;Row1Col3\\nRow2Col1;Row2Col2;Row2Col3\"\n}"
						}
					}
				},
